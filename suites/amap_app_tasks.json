{
  "suite_id": "amap_android_openendworld_v1",
  "app": {
    "name": "高德地图",
    "package": "com.autonavi.minimap",
    "avd_name": "OpenEndWorld",
    "tested_version": "16.13.7.2010"
  },
  "verification_model": {
    "principle": "Rewards are computed from Android runtime permission state and 高德地图 private app data. The evaluator does not inspect screenshots or UI text.",
    "app_data_root": "/data/user/0/com.autonavi.minimap",
    "primary_files": [
      "shared_prefs/MapTextSizeSet.xml",
      "shared_prefs/appLanguage.xml",
      "shared_prefs/SP_NAME_layer_checked.xml",
      "shared_prefs/push_state.xml",
      "databases/aMap.db"
    ],
    "system_sources": [
      "dumpsys package com.autonavi.minimap runtime permissions"
    ]
  },
  "task_templates": [
    {
      "id": "amap_map_text_size_random",
      "category": "display_preferences",
      "description": "随机生成地图文字大小设置任务。",
      "instruction_template": "把高德地图里的地图文字大小改成{target_zh}。",
      "parameters": {
        "options": [
          {
            "id": "small",
            "target": "small",
            "target_zh": "小号",
            "baseline": "std"
          },
          {
            "id": "standard",
            "target": "std",
            "target_zh": "标准",
            "baseline": "large"
          },
          {
            "id": "large",
            "target": "large",
            "target_zh": "大号",
            "baseline": "std"
          }
        ]
      },
      "reward": {
        "max": 1.0,
        "weights": {
          "map_text_size": 1.0
        }
      }
    },
    {
      "id": "amap_language_random",
      "category": "display_preferences",
      "description": "随机生成语言切换任务。",
      "instruction_template": "把高德地图的语言设置改成{target_zh}。",
      "parameters": {
        "options": [
          {
            "id": "follow_system",
            "target": 0,
            "target_zh": "跟随系统",
            "baseline": 1
          },
          {
            "id": "chinese",
            "target": 1,
            "target_zh": "中文",
            "baseline": 0
          },
          {
            "id": "english",
            "target": 2,
            "target_zh": "英文",
            "baseline": 0
          }
        ]
      },
      "reward": {
        "max": 1.0,
        "weights": {
          "language_switch_option": 1.0
        }
      }
    },
    {
